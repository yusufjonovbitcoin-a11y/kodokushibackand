PORT=3001
CLIENT_ORIGIN=http://localhost:3000,http://127.0.0.1:3000,http://localhost:3002,http://127.0.0.1:3002

# Supabase (Dashboard → Settings → API → service_role)
SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here

# OpenAI — prescription image parsing (optional)
OPENAI_API_KEY=sk-...

# Firebase Admin — push notifications (optional, JSON string)
FIREBASE_SERVICE_ACCOUNT_JSON=

# Twilio — SMS alerts (optional)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=

# Medicine reminder scheduler timezone (IANA, e.g. Asia/Tokyo)
MEDICINE_REMINDER_TZ=Asia/Tokyo
